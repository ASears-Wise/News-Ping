{
  "name": "newsping-web",
  "main": ".open-next/worker.js",
  "compatibility_date": "2025-03-27",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets"
  },
  "routes": [
    { "pattern": "newsping.io", "custom_domain": true },
    { "pattern": "www.newsping.io", "custom_domain": true }
  ]
}
